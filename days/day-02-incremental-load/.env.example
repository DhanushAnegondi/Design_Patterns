# Day 02 — Incremental Loader. Copy to .env (git-ignored).

# Default: run fully in-process with moto's S3 mock. No AWS account, no cost, no network.
USE_MOTO=1
S3_BUCKET=bronze-layer
AWS_REGION=us-east-1

# --- LocalStack (real S3 API, still local & free) ---
# 1) docker run --rm -p 4566:4566 localstack/localstack
# 2) set USE_MOTO=0 and the lines below
# USE_MOTO=0
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# --- Real AWS S3 (costs money; needs a real bucket you own) ---
# USE_MOTO=0
# unset AWS_ENDPOINT_URL
# AWS_ACCESS_KEY_ID=<your key>
# AWS_SECRET_ACCESS_KEY=<your secret>
# S3_BUCKET=<your real bucket>
